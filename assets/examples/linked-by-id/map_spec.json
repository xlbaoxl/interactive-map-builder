{
  "schema_version": "1.0",
  "template": "map-list",
  "title": "Generic linked-by-id example",
  "primary_layer": "features",
  "layers": [
    {
      "id": "context",
      "name": "Context",
      "source": {"path": "context.geojson", "format": "geojson"},
      "required": true,
      "id_field": "id",
      "label_field": "name",
      "style": {"fill_color": "#e8eef5", "color": "#a8b6c7", "fill_opacity": 0.4}
    },
    {
      "id": "features",
      "name": "Features",
      "source": {
        "path": "metrics.csv",
        "format": "csv",
        "crs": "EPSG:4326",
        "geometry": {
          "type": "lonlat",
          "x_field": "longitude",
          "y_field": "latitude"
        }
      },
      "required": true,
      "id_field": "id",
      "label_field": "name",
      "popup_fields": ["name", "group"],
      "style": {
        "color_field": "group",
        "radius": 7,
        "categories": {
          "North": "#3b82b8",
          "South": "#e28f41"
        }
      }
    }
  ],
  "linked_view": {
    "layer": "features",
    "x_field": "x",
    "y_field": "y",
    "title": "Synthetic x/y metrics linked by stable feature id"
  },
  "static": {
    "enabled": true,
    "presets": ["slide-16x9", "paper"],
    "source_note": "Synthetic example data (CC0)"
  }
}
